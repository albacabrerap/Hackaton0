<+><!DOCTYPE html>\r\n<html lang=\"es\">\r\n  <head>\r\n    <meta charset=\"UTF-8\" />\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n    <title>Estructuras de Datos - CS2031 Team</title>\r\n    <link rel=\"stylesheet\" href=\"index.css\" />\r\n    <link\r\n      rel=\"stylesheet\"\r\n      href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css\"\r\n    />\r\n  </head>\r\n  <body>\r\n    <div class=\"page\">\r\n      <header class=\"header\">\r\n        <nav class=\"nav\">\r\n          <div class=\"nav__container\">\r\n            <div class=\"nav__brand\">\r\n              <span class=\"nav__logo\">CS2031</span>\r\n            </div>\r\n\r\n            <!-- Hidden checkbox for mobile menu toggle -->\r\n            <input type=\"checkbox\" id=\"nav-toggle\" class=\"nav__checkbox\" />\r\n            <label for=\"nav-toggle\" class=\"nav__toggle\">\r\n              <span class=\"nav__toggle-line nav__toggle-line--top\"></span>\r\n              <span class=\"nav__toggle-line nav__toggle-line--middle\"></span>\r\n              <span class=\"nav__toggle-line nav__toggle-line--bottom\"></span>\r\n            </label>\r\n\r\n            <ul class=\"nav__list\">\r\n              <li class=\"nav__item\">\r\n                <!-- BUG #1: este enlace apunta a la seccion equivocada, deberia ser #hero -->\r\n                <a href=\"#inicio\" class=\"nav__link\">Inicio</a>\r\n              </li>\r\n              <li class=\"nav__item\">\r\n                <!-- BUG #2: este enlace apunta a la seccion equivocada, deberia ser #about -->\r\n                <a href=\"#sobre\" class=\"nav__link\">Acerca de</a>\r\n              </li>\r\n              <li class=\"nav__item\">\r\n                <!-- BUG #3: este enlace apunta a la seccion equivocada, deberia ser #team -->\r\n                <a href=\"#integrantes\" class=\"nav__link\">Equipo</a>\r\n              </li>\r\n            </ul>\r\n          </div>\r\n        </nav>\r\n      </header>\r\n\r\n      <main class=\"main\">\r\n        <section id=\"hero\" class=\"hero\">\r\n          <div class=\"hero__container\">\r\n            <div class=\"hero__content\">\r\n              <h1 class=\"hero__title\">Estructuras de Datos & Algoritmos</h1>\r\n              <p class=\"hero__subtitle\">\r\n                Explorando el mundo de los algoritmos y la eficiencia computacional\r\n              </p>\r\n              <div class=\"hero__actions\">\r\n                <a href=\"#about\" class=\"hero__button hero__button--primary\"\r\n                  >Aprender más</a\r\n                >\r\n                <a\r\n                  href=\"#team\"\r\n                  class=\"hero__button hero__button--secondary\"\r\n                  >Conocer al equipo</a\r\n                >\r\n              </div>\r\n            </div>\r\n            <div class=\"hero__visual\">\r\n              <div class=\"hero__icon\">\r\n                <i class=\"fas fa-project-diagram\"></i>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        <section id=\"about\" class=\"about\">\r\n          <div class=\"about__container\">\r\n            <div class=\"about__header\">\r\n              <h2 class=\"about__title\">¿Qué son las Estructuras de Datos?</h2>\r\n              <p class=\"about__description\">\r\n                La base de todo software eficiente y escalable\r\n              </p>\r\n            </div>\r\n\r\n            <div class=\"about__content\">\r\n              <div class=\"about__card\">\r\n                <div class=\"about__card-icon\">\r\n                  <i class=\"fas fa-layer-group\"></i>\r\n                </div>\r\n                <h3 class=\"about__card-title\">Estructuras Lineales</h3>\r\n                <p class=\"about__card-text\">\r\n                  Arrays, listas enlazadas, pilas y colas son las estructuras\r\n                  fundamentales que permiten organizar y acceder a datos de\r\n                  manera secuencial. Son la base para algoritmos más complejos.\r\n                </p>\r\n              </div>\r\n\r\n              <div class=\"about__card\">\r\n                <div class=\"about__card-icon\">\r\n                  <i class=\"fas fa-sitemap\"></i>\r\n                </div>\r\n                <h3 class=\"about__card-title\">Árboles y Grafos</h3>\r\n                <p class=\"about__card-text\">\r\n                  Los árboles binarios, AVL y grafos representan relaciones\r\n                  jerárquicas y conexiones entre datos. Son esenciales para\r\n                  búsquedas eficientes y navegación en redes.\r\n                </p>\r\n              </div>\r\n\r\n              <div class=\"about__card\">\r\n                <div class=\"about__card-icon\">\r\n                  <i class=\"fas fa-tachometer-alt\"></i>\r\n                </div>\r\n                <h3 class=\"about__card-title\">Complejidad Algorítmica</h3>\r\n                <p class=\"about__card-text\">\r\n                  Entender Big O notation es crucial para escribir código\r\n                  eficiente. La diferencia entre O(n) y O(n²) puede significar\r\n                  segundos vs horas en datasets grandes.\r\n                </p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        <section id=\"team\" class=\"team\">\r\n          <div class=\"team__container\">\r\n            <div class=\"team__header\">\r\n              <h2 class=\"team__title\">Nuestro Equipo</h2>\r\n              <p class=\"team__description\">\r\n                Las personas detrás de este proyecto\r\n              </p>\r\n            </div>\r\n\r\n            <div class=\"team__grid\">\r\n              <!-- INTEGRANTE 1: Reemplaza con tus datos -->\r\n              <div class=\"team-card\">\r\n                <div class=\"team-card__image\">\r\n                  <!-- Aquí tu foto de perfil (URL de GitHub u otra imagen) -->\r\n                  <img\r\n                    src=\"https://picsum.photos/300/300?random=1\"\r\n                    alt=\"Nombre Integrante 1\"\r\n                    class=\"team-card__photo\"\r\n                  />\r\n                </div>\r\n                <div class=\"team-card__content\">\r\n                  <!-- Aquí tu nombre completo -->\r\n                  <h3 class=\"team-card__name\">Nombre Integrante 1</h3>\r\n                  <!-- Aquí tu especialidad o rol -->\r\n                  <p class=\"team-card__role\">Tu Especialidad</p>\r\n                  <div class=\"team-card__social\">\r\n                    <!-- Reemplaza # con tu URL de GitHub -->\r\n                    <a\r\n                      href=\"#\"\r\n                      class=\"team-card__social-link team-card__social-link--github\"\r\n                    >\r\n                      <i class=\"fab fa-github\"></i>\r\n                    </a>\r\n                    <!-- Reemplaza # con tu URL de LinkedIn -->\r\n                    <a\r\n                      href=\"#\"\r\n                      class=\"team-card__social-link team-card__social-link--linkedin\"\r\n                    >\r\n                      <i class=\"fab fa-linkedin\"></i>\r\n                    </a>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </section>\r\n      </main>\r\n\r\n      <footer class=\"footer\">\r\n        <div class=\"footer__container\">\r\n          <div class=\"footer__content\">\r\n            <div class=\"footer__brand\">\r\n              <span class=\"footer__logo\">CS2031</span>\r\n              <p class=\"footer__tagline\">Aprendiendo Estructuras de Datos juntos</p>\r\n            </div>\r\n            <div class=\"footer__links\">\r\n              <a href=\"https://github.com\" class=\"footer__link\">\r\n                <i class=\"fab fa-github\"></i>\r\n                GitHub\r\n              </a>\r\n              <a href=\"https://cs.utec.edu.pe\" class=\"footer__link\">\r\n                <i class=\"fas fa-university\"></i>\r\n                UTEC\r\n              </a>\r\n            </div>\r\n          </div>\r\n          <div class=\"footer__bottom\">\r\n            <p class=\"footer__copyright\">\r\n              &copy; 2025 CS2031 Team. Todos los derechos reservados.\r\n            </p>\r\n          </div>\r\n        </div>\r\n      </footer>\r\n    </div>\r\n  </body>\r\n</html>\r\n
